generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  COMPANY
}

enum ListingType {
  INTERNSHIP
  HACKATHON
}

enum AppStatus {
  APPLIED
  INTERVIEWING
  OFFERED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(STUDENT)
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
  student       Student?
  company       Company?
}

model Student {
  id           String        @id @default(cuid())
  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id])
  branch       String?
  year         Int?
  skills       String[]
  college      String?
  bio          String?
  resumeUrl    String?
  applications Application[]
  alerts       AlertPref?
}

model Company {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id])
  companyName String
  website     String?
  description String?
  verified    Boolean   @default(false)
  listings    Listing[]
}

model Listing {
  id           String        @id @default(cuid())
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id])
  title        String
  type         ListingType
  description  String
  skills       String[]
  branch       String[]
  stipend      String?
  location     String?
  deadline     DateTime
  createdAt    DateTime      @default(now())
  applications Application[]
}

model Application {
  id        String    @id @default(cuid())
  studentId String
  listingId String
  student   Student   @relation(fields: [studentId], references: [id])
  listing   Listing   @relation(fields: [listingId], references: [id])
  status    AppStatus @default(APPLIED)
  notes     String?
  createdAt DateTime  @default(now())
}

model AlertPref {
  id        String   @id @default(cuid())
  studentId String   @unique
  student   Student  @relation(fields: [studentId], references: [id])
  skills    String[]
  branch    String?
  year      Int?
  email     Boolean  @default(true)
  whatsapp  Boolean  @default(false)
  phone     String?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}