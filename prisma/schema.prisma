generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  image         String?
  createdAt     DateTime  @default(now())
  emailVerified DateTime?
  role          Role?

  accounts Account[]
  company  Company?
  sessions Session[]
  student  Student?
}

model Student {
  id        String   @id @default(cuid())
  userId    String   @unique
  branch    String?
  year      Int?
  college   String?
  skills    String[]
  bio       String?
  phone     String?
  resumeUrl          String?
  resumeFileName     String?
  resumeMimeType     String?
  resumeUploadedAt   DateTime?

  applications Application[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Company {
  id          String  @id @default(cuid())
  userId      String  @unique
  name        String
  description String?
  location    String?
  logo        String?
  website     String?

  createdAt DateTime @default(now())
  updatedAt DateTime? @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  listings Listing[]
}

model Listing {
  id          String      @id @default(cuid())
  companyId   String
  title       String
  type        ListingType
  description String
  location    String?
  deadline    DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime?   @updatedAt

  skills String[]

  applications Application[]

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Application {
  id        String    @id @default(cuid())
  studentId String
  listingId String
  status    AppStatus @default(APPLIED)
  createdAt DateTime  @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, listingId])
  @@index([studentId])
  @@index([listingId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum ListingType {
  INTERNSHIP
  HACKATHON
  JOB
}

enum AppStatus {
  APPLIED
  REVIEWING
  INTERVIEWING
  OFFERED
  REJECTED
}

enum Role {
  STUDENT
  COMPANY
}
